# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Flink
CHECKPOINT_INTERVAL_MS=30000

# MinIO (S3-compatible for Iceberg)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_ENDPOINT=http://localhost:9000

# Iceberg
ICEBERG_ENABLED=false
ICEBERG_CATALOG_NAME=olist_catalog
ICEBERG_WAREHOUSE=s3a://warehouse/
ICEBERG_CATALOG_URI=http://localhost:8181

# Olist data path
OLIST_DATA_PATH=./data/
EVENTS_PER_SECOND=50

# Kafka topics
ORDERS_TOPIC=orders
REVENUE_SINK_TOPIC=revenue-by-category
ALERTS_SINK_TOPIC=order-alerts
KPI_SINK_TOPIC=realtime-kpis

# Anomaly thresholds
SUSPICIOUS_ORDER_COUNT=3
PRICE_ANOMALY_THRESHOLD=500
